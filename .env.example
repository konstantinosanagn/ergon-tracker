# ergon-tracker — local configuration. Copy to `.env` and fill in.
# `.env` is gitignored and must never be committed.

# --- Optional keyed sources (free) -------------------------------------------
# Both are skipped silently if unset, so they never break a search.

# Adzuna free search API — https://developer.adzuna.com/
ADZUNA_APP_ID=
ADZUNA_APP_KEY=

# USAJOBS free search API (US federal jobs) — https://developer.usajobs.gov/
# USAJOBS_EMAIL is the email you registered with; it is sent as the required
# User-Agent header (requests are rejected without it).
USAJOBS_API_KEY=
USAJOBS_EMAIL=

# --- Optional semantic search tuning (needs the [semantic] extra) ------------
# Swap the embedding model (e.g. a smaller/quantized variant) or cap CPU threads.
# ERGON_SEMANTIC_MODEL=BAAI/bge-small-en-v1.5
# ERGON_SEMANTIC_THREADS=4
