# Python
__pycache__/
*.py[cod]
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/

# Tooling caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
coverage.xml

# State / cache produced at runtime
.jobspine/
*.sqlite
*.sqlite3

# Large/intermediate extraction artifacts (gold lives in tests/data/, kept).
# Ignore /data/ contents but keep the curated registry CSVs (data/companies/),
# which are version-controlled and verified by the registry-verify CI workflow.
/data/*
!/data/companies/

# Env
.env
.env.*

# OS / editor
.DS_Store
.idea/
.vscode/

# Advisory lockfiles (e.g. seed.json.lock from build_registry concurrency lock)
*.lock

scripts/.h1b_cache/

# wikidata harvester scratch
scripts/.sector_wd_*.json
